Giải thích code
Khai báo biến
int products = 0;
int sells = 0;
products: số sản phẩm đã sản xuất. 
sells: số sản phẩm đã bán. 
Semaphore
sem_t empty;
sem_t full;
empty: số chỗ còn trống để sản xuất. 
full: số sản phẩm đã có để bán. 
Khởi tạo
sem_init(&empty,0,LIMIT);
sem_init(&full,0,0);
Ban đầu:
Có LIMIT chỗ trống. 
Chưa có sản phẩm nào. 
Producer
sem_wait(&empty);
Nếu đã sản xuất đủ LIMIT sản phẩm chưa bán thì Producer sẽ phải chờ.
Sau đó:
products++;
và:
sem_post(&full);
Báo cho Consumer biết đã có thêm một sản phẩm.
Consumer
sem_wait(&full);
Nếu chưa có sản phẩm thì Consumer sẽ phải chờ.
Sau đó:
sells++;
rồi:
sem_post(&empty);
Thông báo đã có thêm một chỗ trống để Producer tiếp tục sản xuất.

BÀI 2 - Đồng bộ mảng bằng Semaphore
Theo đề bài, có 2 thread chạy song song: 
Thread 1: sinh số ngẫu nhiên và thêm vào mảng a. 
Thread 2: lấy một phần tử ra khỏi mảng. 
Ban đầu chạy không đồng bộ để thấy lỗi, sau đó dùng semaphore để đồng bộ. 
Bước 1: Tạo file
cd ~/lab5
xed bai2.c &
Bước 2: Viết code
#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>
#include <unistd.h>
#include <semaphore.h>
#include <time.h>

int a[100];
int n = 0;

sem_t mutex;

void *them(void *arg)
{
    while(1)
    {
        sem_wait(&mutex);

        if(n < 100)
        {
            int x = rand() % 100;
            a[n] = x;
            n++;

            printf("Them %d   So phan tu = %d\n", x, n);
        }

        sem_post(&mutex);

        sleep(1);
    }
}

void *xoa(void *arg)
{
    while(1)
    {
        sem_wait(&mutex);

        if(n == 0)
        {
            printf("Nothing in array a\n");
        }
        else
        {
            printf("Lay %d   So phan tu = %d\n", a[n-1], n-1);
            n--;
        }

        sem_post(&mutex);

        sleep(2);
    }
}

int main()
{
    srand(time(NULL));

    pthread_t t1, t2;

    sem_init(&mutex,0,1);

    pthread_create(&t1,NULL,them,NULL);
    pthread_create(&t2,NULL,xoa,NULL);

    pthread_join(t1,NULL);
    pthread_join(t2,NULL);

    sem_destroy(&mutex);

    return 0;
}
