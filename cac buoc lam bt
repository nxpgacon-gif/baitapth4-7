#include <stdio.h>
#include <pthread.h>
#include <unistd.h>

int x = 0;

void *processA(void *arg)
{
    while(1)
    {
        x++;

        if(x==20)
            x=0;

        printf("A: %d\n",x);

        usleep(200000);
    }
}

void *processB(void *arg)
{
    while(1)
    {
        x++;

        if(x==20)
            x=0;

        printf("B: %d\n",x);

        usleep(200000);
    }
}

int main()
{
    pthread_t t1,t2;

    pthread_create(&t1,NULL,processA,NULL);
    pthread_create(&t2,NULL,processB,NULL);

    pthread_join(t1,NULL);
    pthread_join(t2,NULL);

    return 0;
}
