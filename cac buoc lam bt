#include <stdio.h>
#include <pthread.h>
#include <unistd.h>
#include <semaphore.h>

int products = 0;
int sells = 0;

// Thay 35 bằng (2 số cuối MSSV + 10)
#define LIMIT 35

sem_t empty;
sem_t full;

void *producer(void *arg)
{
    while(1)
    {
        sem_wait(&empty);

        products++;

        printf("San xuat: products = %d, sells = %d\n", products, sells);

        sem_post(&full);

        sleep(1);
    }
}

void *consumer(void *arg)
{
    while(1)
    {
        sem_wait(&full);

        sells++;

        printf("Ban hang: products = %d, sells = %d\n", products, sells);

        sem_post(&empty);

        sleep(2);
    }
}

int main()
{
    pthread_t t1, t2;

    sem_init(&empty, 0, LIMIT);
    sem_init(&full, 0, 0);

    pthread_create(&t1, NULL, producer, NULL);
    pthread_create(&t2, NULL, consumer, NULL);

    pthread_join(t1, NULL);
    pthread_join(t2, NULL);

    sem_destroy(&empty);
    sem_destroy(&full);

    return 0;
}
